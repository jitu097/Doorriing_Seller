# Netlify Cache-Control Headers
# Place this file in the /public/ folder so it gets copied to the build output.
#
# Hashed asset files: cache for 1 year (immutable — filename changes on every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry point: never cache (always re-fetch to get latest asset hashes)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Service worker (if used): never cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
